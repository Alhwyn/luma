{
  "name": "@alhwyn/luma",
  "version": "0.1.1",
  "description": "Unofficial TypeScript SDK for the Luma API",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Alhwyn/luma.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "luma",
    "events",
    "api",
    "sdk",
    "typescript"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "workspaces": [
    ".",
    "cli"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "luma": "bun cli/src/index.ts",
    "build:api": "bun build ./src/index.ts --outdir dist --target node --format esm && tsc -p tsconfig.build.json",
    "build:cli": "bun run --cwd cli build",
    "build": "bun run build:api && bun run build:cli",
    "test": "bun test",
    "prepublishOnly": "bun run build:api",
    "publish:npm": "npm publish --access public",
    "generate:types": "openapi-typescript https://public-api.luma.com/openapi.json -o src/types/generated.d.ts"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "bun-types": "^1.3.14",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5"
  }
}
